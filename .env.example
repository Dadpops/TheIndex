# =============================================================================
# The Index — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in your Supabase project values.
#
# The app runs WITHOUT these variables using a bundled local seed dataset
# (see /lib/data). Provide them to switch the data layer to a real Supabase
# Postgres backend. The presence of NEXT_PUBLIC_SUPABASE_URL is what flips the
# data layer from local seed -> Supabase.
# -----------------------------------------------------------------------------

# Public project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose to the browser; protected by RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Never prefixed with NEXT_PUBLIC.
# Used by seed scripts and admin server actions that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=
